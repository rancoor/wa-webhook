# WhatsApp Cloud API Webhook Config
PORT=3000

# This token must match what you set in Meta Developer Console → Webhooks → Verify Token
VERIFY_TOKEN=my_secret_verify_token

# Your WhatsApp Cloud API access token (from Meta Developer Console)
WHATSAPP_API_TOKEN=your_access_token_here

# Your WhatsApp Phone Number ID (from Meta Developer Console)
PHONE_NUMBER_ID=your_phone_number_id_here
