<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WA Webhook Receiver</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0f0a;
    --surface: #111811;
    --surface2: #182018;
    --border: #2a3a2a;
    --green: #25d366;
    --green-dim: #1a9e4a;
    --green-glow: rgba(37,211,102,0.12);
    --text: #e8f0e8;
    --text-dim: #7a9a7a;
    --text-muted: #3d5a3d;
    --red: #ff5555;
    --amber: #ffb347;
    --radius: 8px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'IBM Plex Sans',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; display:flex; flex-direction:column; }

  header {
    display:flex; align-items:center; justify-content:space-between;
    padding:14px 24px; border-bottom:1px solid var(--border);
    background:var(--surface); position:sticky; top:0; z-index:10;
  }
  .logo { display:flex; align-items:center; gap:10px; font-family:'IBM Plex Mono',monospace; font-weight:600; font-size:15px; color:var(--green); letter-spacing:-.5px; }
  .logo svg { width:22px; height:22px; }
  .status-pill { display:flex; align-items:center; gap:6px; font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--text-dim); background:var(--surface2); border:1px solid var(--border); border-radius:20px; padding:4px 12px; }
  .dot { width:7px; height:7px; border-radius:50%; background:var(--text-muted); transition:background .3s; }
  .dot.on { background:var(--green); animation:pulse 2s infinite; }
  .dot.err { background:var(--red); }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.4} }

  .app { display:flex; flex:1; min-height:0; height:calc(100vh - 53px); }

  aside { width:300px; flex-shrink:0; background:var(--surface); border-right:1px solid var(--border); display:flex; flex-direction:column; overflow-y:auto; }
  .section { padding:16px 20px; border-bottom:1px solid var(--border); }
  .section-label { font-family:'IBM Plex Mono',monospace; font-size:10px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:10px; }
  .info-row { display:flex; flex-direction:column; gap:3px; margin-bottom:10px; }
  .info-row label { font-size:10px; color:var(--text-muted); }
  .copy-row { display:flex; gap:6px; }
  .copy-row input { flex:1; background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius); padding:7px 10px; font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--text); outline:none; }
  .btn-icon { background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius); padding:0 10px; cursor:pointer; color:var(--text-dim); font-size:13px; transition:all .2s; }
  .btn-icon:hover { border-color:var(--green-dim); color:var(--green); }

  .contacts-list { list-style:none; flex:1; }
  .contact-item { display:flex; align-items:center; gap:10px; padding:10px 16px; cursor:pointer; transition:background .15s; border-bottom:1px solid var(--surface2); }
  .contact-item:hover { background:var(--surface2); }
  .contact-item.active { background:var(--green-glow); border-left:2px solid var(--green); padding-left:14px; }
  .avatar { width:36px; height:36px; border-radius:50%; background:var(--surface2); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; font-weight:600; font-size:13px; color:var(--green); flex-shrink:0; }
  .contact-info { flex:1; min-width:0; }
  .contact-name { font-size:13px; font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .contact-preview { font-size:11px; color:var(--text-dim); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; margin-top:2px; }
  .contact-time { font-size:10px; color:var(--text-muted); font-family:'IBM Plex Mono',monospace; flex-shrink:0; }
  .badge { background:var(--green); color:#000; border-radius:10px; font-size:10px; font-weight:700; padding:1px 6px; }
  .empty-contacts { padding:24px 16px; color:var(--text-muted); font-size:11px; text-align:center; font-family:'IBM Plex Mono',monospace; line-height:1.7; }

  main { flex:1; display:flex; flex-direction:column; min-width:0; }
  .no-selection { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:14px; color:var(--text-muted); }
  .no-selection h3 { font-size:16px; font-weight:500; color:var(--text-dim); }
  .no-selection p { font-size:12px; font-family:'IBM Plex Mono',monospace; text-align:center; max-width:300px; line-height:1.7; }

  #chat-view { display:none; flex-direction:column; height:100%; }
  .chat-header { padding:12px 20px; border-bottom:1px solid var(--border); background:var(--surface); display:flex; align-items:center; justify-content:space-between; }
  .chat-contact { display:flex; align-items:center; gap:10px; }
  .chat-contact .name { font-weight:600; font-size:14px; }
  .chat-contact .phone { font-size:11px; color:var(--text-dim); font-family:'IBM Plex Mono',monospace; }

  .messages { flex:1; overflow-y:auto; padding:20px; display:flex; flex-direction:column; gap:10px; }
  .messages::-webkit-scrollbar { width:4px; }
  .messages::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }

  .msg { max-width:68%; display:flex; flex-direction:column; gap:3px; animation:msgIn .2s ease; }
  @keyframes msgIn { from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)} }
  .msg.inbound { align-self:flex-start; }
  .msg.outbound { align-self:flex-end; }
  .bubble { padding:9px 13px; border-radius:12px; font-size:13px; line-height:1.5; }
  .msg.inbound .bubble { background:var(--surface2); border:1px solid var(--border); border-bottom-left-radius:4px; }
  .msg.outbound .bubble { background:#1a4a2a; border:1px solid #2a6a3a; border-bottom-right-radius:4px; }
  .msg-meta { display:flex; gap:6px; align-items:center; font-size:10px; color:var(--text-muted); font-family:'IBM Plex Mono',monospace; }
  .msg.outbound .msg-meta { justify-content:flex-end; }
  .msg-type-tag { background:var(--surface2); border:1px solid var(--border); border-radius:4px; padding:1px 5px; font-size:9px; color:var(--text-muted); text-transform:uppercase; }

  /* log */
  .log-panel { height:150px; border-top:1px solid var(--border); background:#060a06; overflow-y:auto; flex-shrink:0; }
  .log-header { padding:6px 14px; border-bottom:1px solid var(--border); font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--text-muted); display:flex; justify-content:space-between; align-items:center; position:sticky; top:0; background:#060a06; }
  .log-entries { padding:4px 14px 8px; }
  .log-entry { font-family:'IBM Plex Mono',monospace; font-size:11px; line-height:1.7; color:var(--text-muted); }
  .log-entry .ts { color:var(--green-dim); }
  .log-entry .lvl-info { color:var(--green); }
  .log-entry .lvl-warn { color:var(--amber); }
  .log-entry .lvl-err  { color:var(--red); }

  .btn { padding:7px 14px; border-radius:var(--radius); font-family:'IBM Plex Sans',sans-serif; font-weight:600; font-size:12px; cursor:pointer; transition:all .2s; border:1px solid var(--border); background:transparent; color:var(--text-dim); }
  .btn:hover { border-color:var(--green-dim); color:var(--green); }
  .btn.danger:hover { border-color:var(--red); color:var(--red); }

  #toast { position:fixed; bottom:24px; right:24px; background:var(--surface); border:1px solid var(--green-dim); color:var(--green); border-radius:var(--radius); padding:10px 16px; font-size:12px; font-family:'IBM Plex Mono',monospace; transform:translateY(20px); opacity:0; transition:all .25s; pointer-events:none; z-index:100; box-shadow:0 4px 20px rgba(0,0,0,.4); }
  #toast.show { transform:translateY(0); opacity:1; }
  #toast.error { border-color:var(--red); color:var(--red); }

  aside::-webkit-scrollbar { width:3px; }
  aside::-webkit-scrollbar-thumb { background:var(--border); }
</style>
</head>
<body>

<header>
  <div class="logo">
    <svg viewBox="0 0 24 24" fill="none">
      <path d="M17.6 6.4A8 8 0 1 0 19.9 15l2.1.6-1.8-4.9A8 8 0 0 0 17.6 6.4z" fill="#25d366"/>
      <circle cx="9"  cy="12" r="1" fill="#000"/>
      <circle cx="12" cy="12" r="1" fill="#000"/>
      <circle cx="15" cy="12" r="1" fill="#000"/>
    </svg>
    WA Webhook Receiver
  </div>
  <div class="status-pill">
    <span class="dot" id="ws-dot"></span>
    <span id="ws-status">Connecting…</span>
  </div>
</header>

<div class="app">
  <aside>
    <!-- Webhook info -->
    <div class="section">
      <div class="section-label">Webhook Endpoint</div>
      <div class="info-row">
        <label>Callback URL (paste into Meta)</label>
        <div class="copy-row">
          <input id="webhook-url" type="text" readonly>
          <button class="btn-icon" onclick="copyEl('webhook-url')" title="Copy">⎘</button>
        </div>
      </div>
      <div class="info-row">
        <label>Verify Token (paste into Meta)</label>
        <div class="copy-row">
          <input id="verify-token" type="text" readonly>
          <button class="btn-icon" onclick="copyEl('verify-token')" title="Copy">⎘</button>
        </div>
      </div>
    </div>

    <!-- Conversations -->
    <div class="section" style="padding-bottom:8px">
      <div class="section-label">Conversations</div>
    </div>
    <ul class="contacts-list" id="contacts-list">
      <li class="empty-contacts">No messages yet.<br><br>Point your Meta webhook to this server and incoming messages will appear here.</li>
    </ul>
  </aside>

  <main>
    <div class="no-selection" id="no-selection">
      <svg width="56" height="56" viewBox="0 0 24 24" fill="none">
        <path d="M17.6 6.4A8 8 0 1 0 19.9 15l2.1.6-1.8-4.9A8 8 0 0 0 17.6 6.4z" fill="#25d366" opacity=".25"/>
      </svg>
      <h3>No conversation selected</h3>
      <p>Select a conversation from the left, or wait for incoming WhatsApp messages.</p>
    </div>

    <div id="chat-view">
      <div class="chat-header">
        <div class="chat-contact">
          <div class="avatar" id="chat-avatar">?</div>
          <div>
            <div class="name" id="chat-name">—</div>
            <div class="phone" id="chat-phone">—</div>
          </div>
        </div>
        <div style="display:flex;gap:8px">
          <button class="btn" onclick="clearChat()">Clear</button>
        </div>
      </div>

      <div class="messages" id="messages"></div>

      <div class="log-panel">
        <div class="log-header">
          <span>WEBHOOK LOG</span>
          <button onclick="clearLog()" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:10px;font-family:inherit">CLEAR</button>
        </div>
        <div class="log-entries" id="log-entries"></div>
      </div>
    </div>
  </main>
</div>

<div id="toast"></div>

<script>
// ── State ───────────────────────────────────────────
let conversations = {};
let activePhone   = null;
let ws;

// ── Boot ────────────────────────────────────────────
(async function init() {
  // Fetch config from server
  try {
    const res = await fetch('/api/config');
    const cfg = await res.json();
    document.getElementById('webhook-url').value  = cfg.webhookUrl;
    document.getElementById('verify-token').value = cfg.verifyToken;
  } catch(e) {
    log('err', 'Could not fetch server config');
  }
  connectWs();
})();

// ── WebSocket ────────────────────────────────────────
function connectWs() {
  const proto = location.protocol === 'https:' ? 'wss' : 'ws';
  ws = new WebSocket(`${proto}://${location.host}/ws`);

  ws.onopen = () => {
    setWsStatus(true);
    log('info', 'WebSocket connected to server');
  };

  ws.onclose = () => {
    setWsStatus(false);
    log('warn', 'WebSocket disconnected — retrying in 3s');
    setTimeout(connectWs, 3000);
  };

  ws.onerror = () => log('err', 'WebSocket error');

  ws.onmessage = (e) => {
    try {
      const { event, data } = JSON.parse(e.data);
      if (event === 'message') handleIncoming(data);
      if (event === 'status')  log('info', `Status update: msg ${data.id} → ${data.status}`);
    } catch(err) {
      log('err', 'Bad WS message: ' + err.message);
    }
  };
}

function setWsStatus(on) {
  const dot = document.getElementById('ws-dot');
  const lbl = document.getElementById('ws-status');
  dot.className = 'dot ' + (on ? 'on' : 'err');
  lbl.textContent = on ? 'Live · /webhook' : 'Disconnected';
}

// ── Incoming message ─────────────────────────────────
function handleIncoming(msg) {
  const { from: phone, name, text, type, timestamp } = msg;
  const ts = new Date(parseInt(timestamp) * 1000).toISOString();

  if (!conversations[phone]) conversations[phone] = { name, messages: [], unread: 0 };
  conversations[phone].name = name;
  conversations[phone].messages.push({ id: msg.id, dir: 'inbound', text, type, ts });
  if (activePhone !== phone) conversations[phone].unread++;

  renderContacts();
  if (activePhone === phone) renderMessages(phone);
  log('info', `Inbound from ${name} (${phone}): "${text}"`);
  toast(`New message from ${name}`);
}

// ── Render contacts ───────────────────────────────────
function renderContacts() {
  const list = document.getElementById('contacts-list');
  const phones = Object.keys(conversations);
  if (!phones.length) {
    list.innerHTML = '<li class="empty-contacts">No messages yet.<br><br>Point your Meta webhook here.</li>';
    return;
  }
  list.innerHTML = phones.map(ph => {
    const c    = conversations[ph];
    const last = c.messages[c.messages.length - 1];
    const preview = last ? last.text.slice(0,38) + (last.text.length>38?'…':'') : '';
    const time    = last ? fmtTime(last.ts) : '';
    const unread  = c.unread || 0;
    const init    = c.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
    return `<li class="contact-item ${ph===activePhone?'active':''}" onclick="selectConversation('${ph}')">
      <div class="avatar">${init}</div>
      <div class="contact-info">
        <div class="contact-name">${esc(c.name)}</div>
        <div class="contact-preview">${esc(preview)}</div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px">
        <span class="contact-time">${time}</span>
        ${unread ? `<span class="badge">${unread}</span>` : ''}
      </div>
    </li>`;
  }).join('');
}

// ── Select conversation ───────────────────────────────
function selectConversation(phone) {
  activePhone = phone;
  if (conversations[phone]) conversations[phone].unread = 0;
  renderContacts();
  const c = conversations[phone];
  const init = c.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('chat-avatar').textContent = init;
  document.getElementById('chat-name').textContent   = c.name;
  document.getElementById('chat-phone').textContent  = '+' + phone;
  document.getElementById('no-selection').style.display = 'none';
  const cv = document.getElementById('chat-view');
  cv.style.display = 'flex';
  renderMessages(phone);
}

// ── Render messages ───────────────────────────────────
function renderMessages(phone) {
  const msgs = conversations[phone]?.messages || [];
  const el   = document.getElementById('messages');
  if (!msgs.length) {
    el.innerHTML = '<div style="text-align:center;color:var(--text-muted);font-size:12px;font-family:\'IBM Plex Mono\',monospace;padding-top:40px">No messages yet</div>';
    return;
  }
  el.innerHTML = msgs.map(m => `
    <div class="msg ${m.dir}">
      <div class="bubble">${esc(m.text)}</div>
      <div class="msg-meta">
        <span>${fmtTime(m.ts, true)}</span>
        ${m.type !== 'text' ? `<span class="msg-type-tag">${m.type}</span>` : ''}
      </div>
    </div>`).join('');
  el.scrollTop = el.scrollHeight;
}

// ── Actions ───────────────────────────────────────────
function clearChat() {
  if (!activePhone) return;
  conversations[activePhone].messages = [];
  renderMessages(activePhone);
}

function clearLog() { document.getElementById('log-entries').innerHTML = ''; }

// ── Log ───────────────────────────────────────────────
function log(level, msg) {
  const el  = document.getElementById('log-entries');
  const ts  = new Date().toLocaleTimeString('en-GB', { hour12: false });
  const map = { info: 'lvl-info', warn: 'lvl-warn', err: 'lvl-err' };
  const d   = document.createElement('div');
  d.className = 'log-entry';
  d.innerHTML = `<span class="ts">[${ts}]</span> <span class="${map[level]||''}">${level.toUpperCase()}</span> ${esc(msg)}`;
  el.appendChild(d);
  el.parentElement.scrollTop = el.parentElement.scrollHeight;
}

// ── Helpers ───────────────────────────────────────────
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function fmtTime(iso, full=false) {
  const d   = new Date(iso);
  const now = new Date();
  if (full) return d.toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit', hour12:false });
  return d.toDateString() === now.toDateString()
    ? d.toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit', hour12:false })
    : d.toLocaleDateString('en-GB', { day:'2-digit', month:'short' });
}

function copyEl(id) {
  navigator.clipboard.writeText(document.getElementById(id).value).then(() => toast('Copied!'));
}

let toastTimer;
function toast(msg, err=false) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'show' + (err?' error':'');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.className = '', 2500);
}
</script>
</body>
</html>
